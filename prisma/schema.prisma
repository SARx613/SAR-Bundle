// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// --- SAR Bundle ---

enum PricingScope {
  FLAT
  TIERED
}

enum DiscountValueType {
  PERCENT
  FIXED_AMOUNT
  FIXED_PRICE
}

enum ThresholdBasis {
  ITEM_COUNT
  CART_VALUE
}

enum StepRuleMetric {
  BUNDLE_PRICE
  TOTAL_ITEM_COUNT
  VARIANT_QUANTITY
  DISTINCT_VARIANT_COUNT
}

enum StepRuleOperator {
  LT
  LTE
  EQ
  GTE
  GT
}

enum LineItemPropertyFieldType {
  CHECKBOX
  TEXT
}

enum BundleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  /// Aligné sur ProductStatus Shopify (produit actif, lien direct uniquement)
  UNLISTED
}

/// Mode métier affiché dans l’admin (Tarifs & panier). PREDEFINED_SIZES = phase 2.
enum BundlePricingMode {
  STANDARD
  FIXED_PRICE_BOX
  TIERED
  PREDEFINED_SIZES
}

model Bundle {
  id         String @id @default(cuid())
  /// Stable id for storefront line item property `_sar_bundle_id`
  bundleUid  String @unique @default(uuid())
  shopDomain String

  name        String
  description String?
  imageUrl    String?
  imageGid    String?
  /// Galerie produit (ordre = ordre Shopify). Première entrée = image principale / liste admin.
  bundleGallery Json?
  /// Linked catalog product (GID) for SEO, collections, and theme metafield binding
  shopifyProductId String?
  /// Variante du produit « coque » bundle (prix fixe) — seule ligne ajoutée au panier
  shopifyParentVariantId String?
  /// URL slug: /products/{productHandle} (optional; défaut = dérivé du nom)
  productHandle    String?
  seoTitle         String?
  seoDescription   String?
  /// Éditeur visuel (blocs, styles globaux) — JSON versionné
  storefrontDesign Json?

  status BundleStatus @default(DRAFT)

  bundlePricingMode BundlePricingMode @default(STANDARD)
  /// Nombre exact d’articles pour le mode prix fixe (FIXED_PRICE_BOX)
  fixedBoxItemCount Int?
  /// URLs d’illustration par mode (clé = mode) — usage futur
  pricingModeMedia  Json?

  pricingScope       PricingScope
  discountValueType  DiscountValueType
  /// Used when pricingScope is FLAT; interpreted per discountValueType
  flatDiscountValue  Decimal?

  showCompareAtPrice   Boolean @default(true)
  showFixedPriceOnLoad Boolean @default(false)
  allowZeroTotal       Boolean @default(false)

  minTotalItemCount  Int?
  maxTotalItemCount  Int?
  minBundleCartValue Decimal?
  maxBundleCartValue Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingTiers BundlePricingTier[]
  steps        BundleStep[]

  @@index([shopDomain])
}

model BundlePricingTier {
  id       String @id @default(cuid())
  bundleId String
  bundle   Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  thresholdBasis ThresholdBasis
  thresholdMin   Decimal
  thresholdMax   Decimal?
  /// Interpreted per parent Bundle.discountValueType
  tierValue      Decimal

  @@index([bundleId, sortOrder])
}

model BundleStep {
  id       String @id @default(cuid())
  bundleId String
  bundle   Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  name        String?
  description String?
  imageUrl    String?
  imageGid    String?
  isFinalStep Boolean @default(false)

  products           StepProduct[]
  rules              StepRule[]
  lineItemProperties StepLineItemProperty[]

  @@index([bundleId, sortOrder])
}

model StepProduct {
  id     String     @id @default(cuid())
  stepId String
  step   BundleStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  variantGid String
  sortOrder  Int    @default(0)
  minQuantity Int?
  maxQuantity Int?
  /// Handle produit Shopify pour charger /products/{handle}.js (variantes)
  productHandle String?
  /// Disposition carte produit sur la boutique
  layoutPreset  String  @default("STACK_ADD_TO_QTY")
  /// Rayon bouton/image, couleurs, etc. par produit
  styleOverrides Json?

  @@index([stepId, sortOrder])
}

model StepRule {
  id     String     @id @default(cuid())
  stepId String
  step   BundleStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  metric   StepRuleMetric
  operator StepRuleOperator
  value    Decimal

  /// Required when metric is VARIANT_QUANTITY
  targetVariantGid String?

  @@index([stepId, sortOrder])
}

model StepLineItemProperty {
  id     String     @id @default(cuid())
  stepId String
  step   BundleStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  fieldType       LineItemPropertyFieldType
  label           String
  propertyKey     String
  required        Boolean @default(false)
  defaultChecked  Boolean @default(false)
  placeholder     String?

  @@index([stepId, sortOrder])
}

/// Merchant-customized UI text overrides for bundle storefront
model TranslationOverride {
  id         String @id @default(cuid())
  shopDomain String
  /// Translation key, e.g. "btn_add_to_cart", "btn_next", "label_total"
  key        String
  /// Custom text value set by the merchant
  value      String

  @@unique([shopDomain, key])
  @@index([shopDomain])
}

/// Billing plan & monthly revenue tracking per shop
model ShopBilling {
  id                   String   @id @default(cuid())
  shopDomain           String   @unique
  /// free_tier | starter_tier | pro_tier
  activePlan           String   @default("free_tier")
  /// Cumulative bundle revenue since last monthly reset (USD)
  monthlyBundleRevenue Float    @default(0.0)
  /// 1st day of the current calendar month (UTC) — used to detect when to reset
  revenueResetAt       DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([shopDomain])
}
