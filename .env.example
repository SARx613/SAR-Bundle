# Copiez ce fichier vers `.env` à la racine du projet, puis renseignez les valeurs.
#
# DATABASE_URL (obligatoire pour Prisma : migrate, studio, app en local)
# - Développement avec Shopify : `shopify app env pull` crée/met à jour `.env` avec l’URL Postgres gérée par Shopify (si activée pour l’app).
# - Sinon : URL PostgreSQL de votre hébergeur (Render, Neon, Supabase, etc.), format :
#   postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
#
# Sans DATABASE_URL, `npx prisma migrate deploy` échoue avec P1012.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_files,read_orders,write_products
SHOPIFY_APP_URL=
DATABASE_URL=
