# Copiez ce fichier vers `.env` à la racine du projet, puis renseignez les valeurs.
#
# IMPORTANT — `shopify app env pull`
# Cette commande ne met dans .env que ce qui est enregistré côté Shopify (clé API, secret, scopes, URL).
# Elle n’ajoute PAS `DATABASE_URL` tant que vous ne l’avez pas créée vous-même (PostgreSQL externe).
#
# DATABASE_URL (obligatoire pour Prisma : migrate, dev, production)
# Pour SUPABASE, utilisez le Connection Pooling (port 6543) pour DATABASE_URL
# et la connexion directe (port 5432) pour DIRECT_URL.
# 1. Allez dans Dashboard > Project Settings > Database > Connection pool
# 2. Copiez la chaîne de connexion (URI)
#
# Exemple Supabase :
# DATABASE_URL="postgres://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_files,read_orders,write_products
SHOPIFY_APP_URL=
DATABASE_URL=
DIRECT_URL=
