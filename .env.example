# Copiez vers .env et renseignez les valeurs.
# Sur Render / autre hébergement : la variable SCOPES doit inclure les mêmes scopes
# que shopify.app.toml (sinon l’app demande des droits différents et read_orders peut manquer).
#
# Exemple :
# SCOPES=write_files,read_orders,write_products

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_files,read_orders,write_products
SHOPIFY_APP_URL=
DATABASE_URL=
