{% comment %}
  SAR Bundle — Theme App Block (produit lié via metafields custom.sar_bundle_id, custom.sar_bundle_active)
  Template recommandé : product.sar-bundle.json — ajoutez ce bloc à la place de la section produit classique.
{% endcomment %}

{% assign bundle_id = product.metafields.custom.sar_bundle_id.value %}
{% if bundle_id == blank %}
  {% assign bundle_id = product.metafields.custom.sar_bundle_id %}
{% endif %}

{% assign bundle_active = product.metafields.custom.sar_bundle_active.value %}

{% if bundle_id != blank and bundle_active != false %}
  <style>
    /* Masque le formulaire d’ajout au panier natif (Dawn / thèmes classiques). Ajustez si votre thème utilise d’autres sélecteurs. */
    .product-form,
    product-form {
      display: none !important;
    }
  </style>

  <div
    id="sar-bundle-root"
    class="sar-bundle"
    data-sar-bundle-root
    data-bundle-ref="{{ bundle_id | escape }}"
    data-bundle-id="{{ bundle_id | escape }}"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-heading="{{ block.settings.heading | escape }}"
    data-show-progress="{{ block.settings.show_step_progress }}"
    style="
      --sar-color-primary: {{ block.settings.color_primary }};
      --sar-color-border: {{ block.settings.color_border }};
      --sar-color-bg: {{ block.settings.color_background }};
      --sar-color-text: {{ block.settings.color_text }};
      --sar-font-heading: {{ block.settings.font_heading }};
      --sar-font-body: {{ block.settings.font_body }};
      --sar-heading-size: {{ block.settings.heading_size }}px;
      --sar-body-size: {{ block.settings.body_size }}px;
      --sar-padding: {{ block.settings.padding }}px;
      --sar-radius: {{ block.settings.border_radius }}px;
    "
  >
    <div class="sar-bundle__loading" data-sar-loading>Chargement du bundle…</div>
    <div class="sar-bundle__inner" data-sar-inner hidden></div>
  </div>
{% endif %}

{% schema %}
{
  "name": "SAR Bundle Builder",
  "target": "section",
  "stylesheet": "bundle-builder.css",
  "javascript": "bundle-builder.js",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Le bundle est détecté via custom.sar_bundle_id et custom.sar_bundle_active (mis à jour à l’enregistrement dans l’app)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre affiché",
      "default": "Composez votre pack"
    },
    {
      "type": "checkbox",
      "id": "show_step_progress",
      "label": "Afficher la progression des étapes",
      "default": true
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Couleur principale (boutons, sélection)",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Bordures",
      "default": "#e1e3e5"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Arrière-plan du bloc",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Texte",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Police des titres",
      "options": [
        { "value": "inherit", "label": "Thème (héritée)" },
        { "value": "system-ui, sans-serif", "label": "Sans-serif système" },
        { "value": "Georgia, 'Times New Roman', serif", "label": "Serif" },
        { "value": "ui-monospace, monospace", "label": "Monospace" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "font_body",
      "label": "Police du corps",
      "options": [
        { "value": "inherit", "label": "Thème (héritée)" },
        { "value": "system-ui, sans-serif", "label": "Sans-serif système" },
        { "value": "Georgia, 'Times New Roman', serif", "label": "Serif" },
        { "value": "ui-monospace, monospace", "label": "Monospace" }
      ],
      "default": "inherit"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Taille du titre principal",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Taille du texte",
      "default": 15
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Marge intérieure",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Rayon des coins",
      "default": 8
    }
  ]
}
{% endschema %}
