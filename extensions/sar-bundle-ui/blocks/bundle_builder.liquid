{% comment %}
  SAR Bundle — Theme App Block (produit lié via metafields custom.sar_bundle_id, custom.sar_bundle_active)
  IMPORTANT : ce bloc ne doit pas modifier le template global (main-product).
  Ajoutez-le simplement dans l’éditeur de thème, sous la description / bouton d’achat.
{% endcomment %}

{% assign bundle_id = product.metafields.custom.sar_bundle_id.value %}
{% if bundle_id == blank %}
  {% assign bundle_id = product.metafields.custom.sar_bundle_id %}
{% endif %}

{% assign bundle_active = product.metafields.custom.sar_bundle_active.value %}

{% if bundle_id != blank and bundle_active != false %}
  {% assign steps_align = block.settings.steps_align | default: 'center' %}

  {% case steps_align %}
    {% when 'left' %}
      {% assign steps_justify = 'flex-start' %}
    {% when 'right' %}
      {% assign steps_justify = 'flex-end' %}
    {% else %}
      {% assign steps_justify = 'center' %}
  {% endcase %}

  <div
    id="sar-bundle-root"
    class="sar-bundle"
    data-sar-bundle-root
    data-sar-main-js="{{ 'bundle-builder.js' | asset_url }}"
    data-bundle-ref="{{ bundle_id | escape }}"
    data-bundle-id="{{ bundle_id | escape }}"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-heading="{{ block.settings.heading | escape }}"
    data-show-progress="{{ block.settings.show_step_progress }}"
    data-product-title="{{ product.title | escape }}"
    data-product-image="{{ product.featured_image | image_url: width: 400 | escape }}"
    style="
      --sar-color-primary: {{ block.settings.color_primary }};
      --sar-color-border: {{ block.settings.color_border }};
      --sar-color-bg: {{ block.settings.color_background }};
      --sar-color-text: {{ block.settings.color_text }};
      --sar-font-heading: {{ block.settings.font_heading }};
      --sar-font-body: {{ block.settings.font_body }};
      --sar-heading-size: {{ block.settings.heading_size }}px;
      --sar-body-size: {{ block.settings.body_size }}px;
      --sar-padding: {{ block.settings.padding }}px;
      --sar-radius: {{ block.settings.border_radius }}px;
      --sar-steps-justify: {{ steps_justify }};
    "
  >
    <div class="sar-bundle__loading" data-sar-loading>Chargement du bundle…</div>
    <div class="sar-bundle__inner" data-sar-inner hidden></div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      if (!document.querySelector("[data-sar-bundle-root]")) return;
      const style = document.createElement("style");
      style.innerHTML = `
        form[action="/cart/add"] .product-form__buttons,
        form[action="/cart/add"] .product-form__submit,
        .shopify-payment-button,
        product-form .product-form__buttons,
        product-form .shopify-payment-button,
        .product-form__buttons,
        .product-form__submit {
          display: none !important;
        }
      `;
      document.head.appendChild(style);
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "SAR Bundle Builder",
  "target": "section",
  "stylesheet": "bundle-builder.css",
  "javascript": "bundle-loader.js",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Le bundle est détecté via custom.sar_bundle_id et custom.sar_bundle_active (mis à jour à l’enregistrement dans l’app)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre affiché",
      "default": "Composez votre pack"
    },
    {
      "type": "checkbox",
      "id": "show_step_progress",
      "label": "Afficher la progression des étapes",
      "default": true
    },
    {
      "type": "select",
      "id": "steps_align",
      "label": "Alignement des onglets d'étapes",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },

    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Couleur principale (boutons, sélection)",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Bordures",
      "default": "#e1e3e5"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Arrière-plan du bloc",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Texte",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Police des titres",
      "options": [
        { "value": "inherit", "label": "Thème (héritée)" },
        { "value": "system-ui, sans-serif", "label": "Sans-serif système" },
        { "value": "Georgia, 'Times New Roman', serif", "label": "Serif" },
        { "value": "ui-monospace, monospace", "label": "Monospace" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "font_body",
      "label": "Police du corps",
      "options": [
        { "value": "inherit", "label": "Thème (héritée)" },
        { "value": "system-ui, sans-serif", "label": "Sans-serif système" },
        { "value": "Georgia, 'Times New Roman', serif", "label": "Serif" },
        { "value": "ui-monospace, monospace", "label": "Monospace" }
      ],
      "default": "inherit"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Taille du titre principal",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Taille du texte",
      "default": 15
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Marge intérieure",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Rayon des coins",
      "default": 8
    }
  ]
}
{% endschema %}
