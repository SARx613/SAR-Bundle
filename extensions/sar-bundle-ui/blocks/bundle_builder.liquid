{% comment %}
  SAR Bundle — Theme App Block (produit lié via metafields custom.sar_bundle_id, custom.sar_bundle_active)
  IMPORTANT : ce bloc ne doit pas modifier le template global (main-product).
  Ajoutez-le simplement dans l’éditeur de thème, sous la description / bouton d’achat.
{% endcomment %}

{% assign bundle_id = product.metafields.custom.sar_bundle_id.value %}
{% if bundle_id == blank %}
  {% assign bundle_id = product.metafields.custom.sar_bundle_id %}
{% endif %}

{% assign bundle_active = product.metafields.custom.sar_bundle_active.value %}

{% if bundle_id != blank and bundle_active != false %}
  <div
    id="sar-bundle-root"
    class="sar-bundle"
    data-sar-bundle-root
    data-sar-main-js="{{ 'bundle-builder.js' | asset_url }}"
    data-bundle-ref="{{ bundle_id | escape }}"
    data-bundle-id="{{ bundle_id | escape }}"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-shop="{{ shop.permanent_domain | escape }}"
  >
    <div class="sar-bundle__loading" data-sar-loading>Loading bundle…</div>
    <div class="sar-bundle__inner" data-sar-inner hidden></div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      if (!document.querySelector("[data-sar-bundle-root]")) return;
      const style = document.createElement("style");
      style.innerHTML = `
        form[action="/cart/add"] .product-form__buttons,
        form[action="/cart/add"] .product-form__submit,
        .shopify-payment-button,
        product-form .product-form__buttons,
        product-form .shopify-payment-button,
        .product-form__buttons,
        .product-form__submit {
          display: none !important;
        }
      `;
      document.head.appendChild(style);
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "SAR Bundle Builder",
  "target": "section",
  "stylesheet": "bundle-builder.css",
  "javascript": "bundle-loader.js",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}
