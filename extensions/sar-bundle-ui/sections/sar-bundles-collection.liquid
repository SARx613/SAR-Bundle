{% comment %}
  SAR Bundle — grille pour une collection de produits « bundle ».
  Après installation de l’extension : Éditeur de thème → Modèles → Créer un modèle
  basé sur « sar-bundles » (ou renommez ce fichier) et assignez-le à votre collection.
{% endcomment %}

{{ 'sar-bundles-collection.css' | asset_url | stylesheet_tag }}

<div class="sar-bundles-collection page-width section-{{ section.id }}" style="--sar-bc-pad-top: {{ section.settings.padding_top }}px; --sar-bc-pad-bottom: {{ section.settings.padding_bottom }}px; padding-top: var(--sar-bc-pad-top); padding-bottom: var(--sar-bc-pad-bottom);">
  {% if section.settings.show_title %}
    <h1 class="sar-bundles-collection__heading">{{ collection.title }}</h1>
  {% endif %}
  {% if collection.description != blank %}
    <div class="sar-bundles-collection__desc rte">{{ collection.description }}</div>
  {% endif %}

  {% paginate collection.products by section.settings.products_per_page %}
    <ul class="sar-bundles-collection__grid" role="list">
      {% for product in collection.products %}
        <li class="sar-bundles-collection__item">
          <a href="{{ product.url }}" class="sar-bundles-collection__link">
            <div class="sar-bundles-collection__media">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="{% if product.featured_image.aspect_ratio > 0 %}{{ 800 | divided_by: product.featured_image.aspect_ratio | ceil }}{% else %}800{% endif %}"
                >
              {% else %}
                <span class="sar-bundles-collection__no-img" aria-hidden="true"></span>
              {% endif %}
            </div>
            <h2 class="sar-bundles-collection__title">{{ product.title }}</h2>
            <p class="sar-bundles-collection__price">{{ product.price | money }}</p>
          </a>
        </li>
      {% endfor %}
    </ul>
    {% if paginate.pages > 1 %}
      <nav class="sar-bundles-collection__pagination" aria-label="Pagination">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}">← Précédent</a>
        {% endif %}
        <span class="sar-bundles-collection__page">{{ paginate.current_page }} / {{ paginate.pages }}</span>
        {% if paginate.next %}
          <a href="{{ paginate.next.url }}">Suivant →</a>
        {% endif %}
      </nav>
    {% endif %}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "SAR — Collection bundles",
  "tag": "section",
  "class": "section-sar-bundles-collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Afficher le titre de la collection",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "label": "Produits par page",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "SAR — Collection bundles"
    }
  ]
}
{% endschema %}
