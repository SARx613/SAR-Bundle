{% comment %}
  SAR Bundle — ligne panier = produit bundle unique ; composition dans `_sar_bundle_components` (JSON).

  Certaines thèmes masquent les propriétés dont la clé commence par `_`. Le script storefront envoie aussi
  une propriété visible `Composition` (texte multiligne, une ligne par article). Ce snippet affiche d’abord
  le JSON ; à défaut, il affiche le texte `Composition`.

  Dans la boucle des articles (cart / drawer), après le titre / prix de la ligne :
    {% render 'sar-bundle-cart-composition', item: item %}

  Liez `sar-bundle-cart-composition.css` dans `theme.liquid` (ou la feuille du thème) pour le style liste.

  JSON (tableau) : variantGid, variantId, productTitle, variantTitle, imageUrl, quantity

  Exemple React (Hydrogen / panier custom) :
    const raw = line.attributes?.find((a) => a.key === '_sar_bundle_components')?.value
      ?? line.properties?._sar_bundle_components;
    const components = raw ? JSON.parse(raw) : [];
    return components.map((c) => (
      <div key={c.variantId + '-' + c.quantity}>
        {c.imageUrl ? <img src={c.imageUrl} alt="" width={48} height={48} /> : null}
        <span>{c.quantity > 1 ? `${c.quantity}× ` : ''}{c.productTitle}</span>
        {c.variantTitle ? <span> — {c.variantTitle}</span> : null}
      </div>
    ));
{% endcomment %}
{% assign sar_raw = '' %}
{% assign sar_composition_text = '' %}
{% for p in item.properties %}
  {% if p.first == '_sar_bundle_components' %}
    {% assign sar_raw = p.last %}
  {% elsif p.first == 'Composition' %}
    {% assign sar_composition_text = p.last %}
  {% endif %}
{% endfor %}
{% if sar_raw != blank %}
  {% assign sar_components = sar_raw | parse_json %}
  {% if sar_components != blank %}
    <ul class="sar-bundle-cart-composition" data-sar-bundle-cart-composition>
      {% for comp in sar_components %}
        {% assign cq = comp.quantity | default: 1 | plus: 0 %}
        {% assign ct = comp.productTitle | default: '' %}
        {% assign cv = comp.variantTitle | default: '' | strip %}
        {% assign cu = comp.imageUrl | default: '' | strip %}
        <li class="sar-bundle-cart-composition__row">
          {% if cu != blank %}
            <img
              class="sar-bundle-cart-composition__img"
              src="{{ cu | escape }}"
              alt=""
              width="48"
              height="48"
              loading="lazy"
            >
          {% endif %}
          <span class="sar-bundle-cart-composition__text">
            {% if cq > 1 %}<span class="sar-bundle-cart-composition__qty">{{ cq }}×</span> {% endif %}
            <span class="sar-bundle-cart-composition__title">{{ ct | escape }}</span>
            {% if cv != '' and cv != 'Default Title' %}
              <span class="sar-bundle-cart-composition__variant"> — {{ cv | escape }}</span>
            {% endif %}
          </span>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% elsif sar_composition_text != blank %}
  <div
    class="sar-bundle-cart-composition sar-bundle-cart-composition--plain"
    data-sar-bundle-cart-composition
  >
    {{ sar_composition_text | newline_to_br }}
  </div>
{% endif %}
