{% comment %}
  SAR Bundle — grille collection (snippet d’app).
  Dans le modèle collection de votre thème, ajoutez par ex. :
  {% render 'sar-bundles-collection', show_title: true, products_per_page: 24 %}
  Paramètres optionnels : show_title, products_per_page, padding_top, padding_bottom
{% endcomment %}

{% comment %} show_title : défaut true ; passer false pour masquer {% endcomment %}
{% assign _per_page = products_per_page | default: 24 %}
{% assign _pad_top = padding_top | default: 36 %}
{% assign _pad_bottom = padding_bottom | default: 36 %}

{{ 'sar-bundles-collection.css' | asset_url | stylesheet_tag }}

<div
  class="sar-bundles-collection page-width sar-bundles-collection--snippet"
  style="--sar-bc-pad-top: {{ _pad_top }}px; --sar-bc-pad-bottom: {{ _pad_bottom }}px; padding-top: var(--sar-bc-pad-top); padding-bottom: var(--sar-bc-pad-bottom);"
>
  {% unless show_title == false %}
    <h1 class="sar-bundles-collection__heading">{{ collection.title }}</h1>
  {% endunless %}
  {% if collection.description != blank %}
    <div class="sar-bundles-collection__desc rte">{{ collection.description }}</div>
  {% endif %}

  {% paginate collection.products by _per_page %}
    <ul class="sar-bundles-collection__grid" role="list">
      {% for product in collection.products %}
        <li class="sar-bundles-collection__item">
          <a href="{{ product.url }}" class="sar-bundles-collection__link">
            <div class="sar-bundles-collection__media">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="{% if product.featured_image.aspect_ratio > 0 %}{{ 800 | divided_by: product.featured_image.aspect_ratio | ceil }}{% else %}800{% endif %}"
                >
              {% else %}
                <span class="sar-bundles-collection__no-img" aria-hidden="true"></span>
              {% endif %}
            </div>
            <h2 class="sar-bundles-collection__title">{{ product.title }}</h2>
            <p class="sar-bundles-collection__price">{{ product.price | money }}</p>
          </a>
        </li>
      {% endfor %}
    </ul>
    {% if paginate.pages > 1 %}
      <nav class="sar-bundles-collection__pagination" aria-label="Pagination">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}">← Précédent</a>
        {% endif %}
        <span class="sar-bundles-collection__page">{{ paginate.current_page }} / {{ paginate.pages }}</span>
        {% if paginate.next %}
          <a href="{{ paginate.next.url }}">Suivant →</a>
        {% endif %}
      </nav>
    {% endif %}
  {% endpaginate %}
</div>
